def test_search_columns_exact_match():
    """Exact column name match returns score=30."""
    index = _make_index({
        "dbt_columns": {
            "orders": {"order_id": "Primary key", "status": "Order status"},
        },
    })
    patches = _patch_search(index)
    with patches[0], patches[1]:
