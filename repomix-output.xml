        if: runner.os == 'Linux'
        run: |
          uv build --sdist
          SDIST=$(ls dist/*.tar.gz | head -1)
          echo "Checking $SDIST for sensitive paths..."
          FOUND=$(tar -tzf "$SDIST" | grep -E '(\.claude|\.env|\.pypirc|\.aws|\.ssh|id_rsa|id_ed25519|\.pem|\.key|credentials)' || true)
          if [ -n "$FOUND" ]; then
            echo "ERROR: Sensitive paths found in sdist:"
            echo "$FOUND"
