from __future__ import annotations
from typing import Any


def _attr(obj: Any, name: str, default: Any = None) -> Any:
    """Safely get attribute or dict key."""
    try:
        return getattr(obj, name)
    except Exception:
        try:
            return obj[name]  # type: ignore[index]
        except Exception:
            return default


def _deterministic_factor(node_id: Any, step: int) -> float:
    """Small deterministic tie‑breaker based on node identifier and step."""
    s = f"{node_id}-{step}"
    total = sum(ord(ch) for ch in s)
    return (total % 997) * 1e-5


def score(node: Any, state: Any, context: Any = None) -> float:
    """
    Deterministic scoring used for node selection.

    Parameters
    ----------
    node : Any
        Graph node – can be an object with ``id``, ``state``, ``kind`` and optional
        ``tokens`` attributes or a mapping containing those keys.
    state : Any
        Either a graph‑like object providing ``in_degree`` / ``out_degree`` methods
        or the current step index (int).  If it is a graph, ``context`` may hold the
        step number.
    context : Any, optional
        When ``state`` is a graph, this can be the step count (int).  Otherwise ignored.

    Returns
    -------
    float
        Deterministic priority score – higher means higher priority.
    """
    # Base score from node logical state.
    node_state = _attr(node, "state")
    score_val: float = 0.0
    if node_state == "pending":
        score_val += 5.0
    if node_state == "anchor":
        score_val += 10.0

    # Minor boost for certain kinds.
    kind = _attr(node, "kind")
    if kind == "symbol":
        score_val += 1.0
    elif kind == "call":
        score_val += 0.5

    # Identifier length contributes modestly.
    node_id = _attr(node, "id")
    if isinstance(node_id, str):
        score_val += len(node_id) * 0.1

    # Determine graph and step.
    graph = None
    step = 0
    if isinstance(state, int):
        step = state
    else:
        # Assume ``state`` behaves like a graph with degree methods.
        if any(hasattr(state, meth) for meth in ("in_degree", "out_degree")):
            graph = state
            if isinstance(context, int):
                step = context
        else:
            # Fallback: try to extract step from context if possible.
            if isinstance(context, int):
                step = context

    # Incorporate degree information if a graph is available.
    if graph is not None and hasattr(node, "id"):
        try:
            deg_in = graph.in_degree(node_id)  # type: ignore[arg-type]
            deg_out = graph.out_degree(node_id)  # type: ignore[arg-type]
            score_val += (deg_in + deg_out) * 0.5
        except Exception:
            pass

    # Tokens (e.g., token count) add a modest amount.
    tokens = _attr(node, "tokens")
    if isinstance(tokens, (int, float)):
        score_val += min(tokens, 50) * 0.1

    # Small deterministic tie‑breaker.
    if node_id is not None:
        score_val += _deterministic_factor(node_id, step)

    return float(score_val)
