    json_data = {
        "repo": "local/test-abc123",
        "owner": "local",
        "name": "test-abc123",
        "indexed_at": "2025-01-01T00:00:00",
        "index_version": 4,
        "source_files": ["main.py"],
        "languages": {"python": 1},
        "symbols": [{
            "id": "main.py::greet#function",
            "file": "main.py",
            "name": "greet",
            "qualified_name": "greet",
            "kind": "function",
            "language": "python",
            "signature": "def greet()",
            "summary": "",
            "docstring": "",
            "decorators": [],
            "keywords": [],
            "parent": None,
            "line": 1,
            "end_line": 3,
            "byte_offset": 0,
            "byte_length": 20,
            "content_hash": "",
            "ecosystem_context": "",
        }],
        "file_hashes": {"main.py": "hash1"},
        "git_head": "abc",
        "file_summaries": {"main.py": "Greeting module"},
        "source_root": "/tmp/proj",
