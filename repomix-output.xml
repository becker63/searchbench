from __future__ import annotations

import json
from typing import Any, Dict

from .registry import TOOL_MAP


def parse_tool_call(text: str) -> Dict[str, Any]:
    """
    Expected JSON format:
    {"tool": "<name>", "arguments": {...}}
    """
    try:
        data = json.loads(text)
    except json.JSONDecodeError as exc:
        raise ValueError(f"Invalid JSON: {exc}") from exc

    tool_name = data.get("tool")
    args = data.get("arguments", {})

    if tool_name not in TOOL_MAP:
        raise ValueError(f"Unknown tool: {tool_name}")

    return {"tool": tool_name, "arguments": args}


def execute_tool_call(call: Dict[str, Any], score_fn: Any | None = None):
    tool = TOOL_MAP[call["tool"]]
    func = tool.func

    allowed_args = func.__code__.co_varnames
    filtered_args = {k: v for k, v in call["arguments"].items() if k in allowed_args}

    if "symbol_id" in filtered_args:
        from .normalize import normalize_symbol_id

        norm = normalize_symbol_id(str(filtered_args["symbol_id"]))
        filtered_args["symbol_id"] = norm["symbol"]

    if "symbol" in filtered_args:
        from .normalize import normalize_symbol_id

        norm = normalize_symbol_id(str(filtered_args["symbol"]))
        filtered_args["symbol"] = norm["symbol"]

    if "depth" in filtered_args:
        try:
            filtered_args["depth"] = int(filtered_args["depth"])
        except Exception:
            filtered_args["depth"] = 1

    if "file_path" in filtered_args and "file_paths" in filtered_args:
        filtered_args.pop("file_paths", None)

    if "score_fn" in allowed_args:
        return func(**filtered_args, score_fn=score_fn)

    return func(**filtered_args)
