# --- Generic assembler (NASM/GAS style) ---

NASM_STYLE_SOURCE = """\
; Simple x86 NASM example
section .text
    global _start

_start:
    mov eax, 1
    mov ebx, 0
    int 0x80

print_hello:
    push ebp
    mov ebp, esp
    ret

%define BUFFER_SIZE 1024
%macro PROLOGUE 0
    push ebp
    mov ebp, esp
%endmacro

section .data
    msg db "Hello", 0
    len equ $ - msg

section .bss
    buffer resb 1024
"""


def test_parse_nasm_labels():
