import sys
from pathlib import Path


def _bootstrap_repo_root() -> Path:
    """
    Locate the monorepo root before importing harness utilities.
    """
    start = Path(__file__).resolve()
    for path in [start, *start.parents]:
        if path.name == "searchbench":
            return path
