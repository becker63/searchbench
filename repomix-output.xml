        result = resolve_specifier(
            "./utils", "src/app.js", self.SOURCE_FILES
        )
        assert result == "src/utils/index.js"

    def test_dotdot_traversal(self):
        result = resolve_specifier(
            "../app", "src/utils/helpers.js", self.SOURCE_FILES
        )
        assert result == "src/app.js"

