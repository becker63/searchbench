    return LCATask(identity=identity, context=context, gold=gold, repo=str(tmp_path))


def _bundle(gold_hops: int = 0, issue_hops: int = 0) -> ScoreBundle:
    return ScoreEngine().evaluate(
        ScoreContext(
            predicted_files=("a.py",),
            gold_files=("a.py",),
