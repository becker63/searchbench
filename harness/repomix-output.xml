class EvaluationTelemetryArtifact(BaseModel):
    model_config = ConfigDict(arbitrary_types_allowed=True, extra="forbid")

    score_bundle: ScoreBundle
    score_context: ScoreContext
    score_summary: ScoreBundle
    metric_map: dict[str, float | bool] = Field(default_factory=dict)
    canonical_component_states: dict[str, ScoreComponentTelemetryState] = Field(
        default_factory=dict
    )
    compact_score_context: CompactScoreContext

    @classmethod
    def from_scoring(
        cls,
        *,
        score_bundle: ScoreBundle,
        score_context: ScoreContext,
        score_summary: ScoreBundle | None = None,
    ) -> "EvaluationTelemetryArtifact":
        return cls(
            score_bundle=score_bundle,
            score_context=score_context,
            score_summary=score_summary or score_bundle,
            metric_map=score_bundle_metric_map(score_bundle),
            canonical_component_states=score_bundle_component_states(score_bundle),
            compact_score_context=CompactScoreContext.from_score_context(score_context),
        )


def _optional_bool(value: object) -> bool | None:
    return value if isinstance(value, bool) else None


def _optional_int(value: object) -> int | None:
    if isinstance(value, bool):
        return None
    return value if isinstance(value, int) else None


def _int_or_count(value: object, fallback: Mapping[str, object]) -> int:
    if isinstance(value, bool):
        return 0
    if isinstance(value, int):
        return value
    return sum(1 for item in fallback.values() if item)


def score_bundle_metric_map(bundle: ScoreBundle) -> dict[str, float | bool]:
    metrics: dict[str, float | bool] = {}
    if bundle.composed_score is not None:
        metrics["composed_score"] = float(bundle.composed_score)
    for component_name, result in bundle.results.items():
        stable_name = result.name or component_name
        if not result.available or not isinstance(result.value, (int, float)):
            continue
        metrics[stable_name] = float(result.value)
    return metrics


def _component_value(value: object) -> float | bool | None:
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return float(value)
    return None


def _bundle_component_state(
    bundle: ScoreBundle,
    component_name: str,
) -> ScoreComponentTelemetryState:
    if component_name == "composed_score":
        if bundle.composed_score is None:
            return ScoreComponentTelemetryState(
                available=False,
                value=None,
                reason="composed score unavailable",
            )
        return ScoreComponentTelemetryState(
            available=True,
            value=float(bundle.composed_score),
            reason=None,
        )
    result = bundle.results.get(component_name)
    if result is None:
        return ScoreComponentTelemetryState(
            available=False,
            value=None,
            reason="score component missing from bundle",
        )
    return ScoreComponentTelemetryState(
        available=bool(result.available),
        value=_component_value(result.value),
        reason=result.reason,
    )


def score_bundle_component_states(
    bundle: ScoreBundle,
) -> dict[str, ScoreComponentTelemetryState]:
    return {
        component_name: _bundle_component_state(bundle, component_name)
        for component_name in LOCALIZATION_CANONICAL_COMPONENTS
    }


def evaluation_metrics_map(metrics: object) -> dict[str, float | bool]:
    metric_map: dict[str, float | bool] = {}
    score = getattr(metrics, "score", None)
    if isinstance(score, bool):
        metric_map["metrics.score"] = score
    elif isinstance(score, (int, float)):
        metric_map["metrics.score"] = float(score)
    for entry in getattr(metrics, "additional_metrics", []) or []:
        name = getattr(entry, "name", None)
        value = getattr(entry, "value", None)
        if not isinstance(name, str) or not name:
            continue
        if isinstance(value, bool):
            metric_map[name] = value
        elif isinstance(value, (int, float)):
            metric_map[name] = float(value)
    return metric_map


def optimize_component_states(
    metrics: object,
    *,
    score_component_states: Mapping[str, ScoreComponentTelemetryState] | None = None,
    pipeline_passed: bool | None = None,
) -> dict[str, ScoreComponentTelemetryState]:
    metric_map = evaluation_metrics_map(metrics)
    states: dict[str, ScoreComponentTelemetryState] = {}
    composed_state = (
        score_component_states.get("composed_score")
        if score_component_states is not None
        else None
    )
    if composed_state is not None:
        states["metrics.score"] = composed_state
    else:
        metric_score = metric_map.get("metrics.score")
        states["metrics.score"] = ScoreComponentTelemetryState(
            available=metric_score is not None,
            value=metric_score,
            reason=None if metric_score is not None else "metrics.score unavailable",
        )
    for component_name in ("gold_hop", "issue_hop", "token_efficiency"):
        component_state = (
            score_component_states.get(component_name)
            if score_component_states is not None
            else None
        )
        if component_state is not None:
            states[component_name] = component_state
            continue
        metric_value = metric_map.get(component_name)
        states[component_name] = ScoreComponentTelemetryState(
            available=metric_value is not None,
            value=metric_value,
            reason=None if metric_value is not None else f"{component_name} unavailable",
        )
    states["pipeline_passed"] = ScoreComponentTelemetryState(
        available=pipeline_passed is not None,
        value=pipeline_passed,
        reason=None if pipeline_passed is not None else "pipeline result unavailable",
    )
    for metric_name, value in metric_map.items():
        if metric_name in OPTIMIZE_CANONICAL_COMPONENTS:
            continue
        states[metric_name] = ScoreComponentTelemetryState(
            available=True,
            value=value,
            reason=None,
        )
    return states


__all__ = [
    "BackendRunStats",
    "CompactScoreContext",
    "EvaluationTelemetryArtifact",
    "LocalizationTaskTelemetryContext",
    "LOCALIZATION_CANONICAL_COMPONENTS",
