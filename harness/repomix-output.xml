        result = run_async(_sample_coroutine(loop_ids))
        return outer_loop_id, result

    outer_loop_id, result = asyncio.run(_inner())
    assert result == "ok"
    assert loop_ids  # captured inner loop id
    assert loop_ids[0] != outer_loop_id


