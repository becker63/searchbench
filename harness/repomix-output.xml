    available_tools: str

    @field_validator("available_tools")
    @classmethod
    def _ensure_non_empty(cls, value: str) -> str:
        if not value or not value.strip():
            raise ValueError("available_tools must be non-empty")
        return value


class BackendPromptContext(BaseModel):
