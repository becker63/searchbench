    """
    session_prefix = command.replace(" ", "-")
    session_id = explicit_session_id or f"{session_prefix}-{uuid.uuid4().hex[:8]}"
    return SessionConfig(
        session_id=session_id,
        session_scope="run",
        allow_generated_fallback=False,
    )


