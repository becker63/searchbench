    return LCATask(
        identity=identity,
        context=LCAContext(issue_title="bug", issue_body="details"),
        gold=LCAGold(changed_files=["a.py"]),
        repo="repo",
    )


def _evaluation() -> EvaluationResult:
    return EvaluationResult(
        metrics=EvaluationMetrics.model_validate({"score": 1.0}),
